{
  "meta_deck_path": "meta_deck.json",
  "save_path": "models/attention_enhanced",
  "checkpoint_dir": "./checkpoints/attention_enhanced/",
  "tensorboard_dir": "./logs/attention_enhanced/",
  "resume_path": null,
  "total_timesteps": 30000000,
  "checkpoint_freq": 2000,
  "base_learning_rate": 2e-05,
  "min_learning_rate": 1e-06,
  "warmup_ratio": 0.02,
  "n_steps": 128,
  "batch_size": 2048,
  "n_epochs": 6,
  "gamma": 0.98,
  "gae_lambda": 0.95,
  "ent_coef": 0.025,
  "vf_coef": 0.5,
