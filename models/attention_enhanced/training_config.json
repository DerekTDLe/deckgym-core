  "max_grad_norm": 1.0,
  "target_kl": 0.012,
  "use_attention": true,
  "attention_embed_dim": 256,
  "attention_num_heads": 8,
  "attention_num_layers": 3,
  "policy_layers": [
    512,
    384,
    256
  ],
  "value_layers": [
    512,
    384
  ],
  "use_silu": true,
  "frozen_opponent_update_rollouts": 8,
  "max_turns": 99,
  "max_actions_per_turn": 50,
  "max_total_actions": 1000,
  "n_envs": 128,
  "use_batched_env": true,
  "device": "auto",
  "brutal_resume": false
